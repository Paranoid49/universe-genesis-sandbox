{
  "name": "universe-genesis-sandbox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "npm run test:unit && npm run test:ui",
    "test:unit": "vitest run",
    "test:ui": "vitest run --config vitest.ui.config.ts",
    "test:e2e": "playwright test",
    "test:coverage": "npm run test:coverage:sim && npm run test:coverage:ui",
    "test:coverage:sim": "vitest run --coverage",
    "test:coverage:ui": "vitest run --config vitest.ui.config.ts --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint .",
    "check:bundle": "node scripts/check-build-budget.mjs",
    "check:release": "npm run check && npm run test:e2e",
    "check": "npm run lint && npm run typecheck && npm run test:coverage && npm run test:ui && npm run build && npm run check:bundle"
  },
  "dependencies": {
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
